// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ActionType {
  RAM_OPTIMISATION // {"moneySaved": 250, "oldCost": 500}
  HIRED_EMPLOYEE // {"employeeName": "John", "role": "Barista"}
  DELETED_SHIFT // {"shiftId": "1234-5678", "reason": "sick leave"}
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  username        String    @unique
  passwordHash    String
  BusinessName    String
  createdAt       DateTime  @default(now())

  employees       Employee[]
  ActivityLog     ActivityLog[]
} 

model Employee {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  user          User        @relation(fields: [userId], references: [id])
  name          String
  role          String        //for now
  hourlyWage    Float
  shifts        Shift[]
}

model Shift {
  id            String      @id @default(uuid()) @db.Uuid
  employeeId    String      @db.Uuid
  employee      Employee    @relation(fields: [employeeId], references: [id])
  startTime     DateTime
  endTime       DateTime
  isOptimised   Boolean     @default(false) // optimised or nah
}

model ActivityLog {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  user          User        @relation(fields: [userId], references: [id])
  actionType    ActionType
  metadata      Json?

  createdAt     DateTime
}