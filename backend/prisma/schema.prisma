// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ActionType {
  RAM_OPTIMISATION // {"moneySaved": 250, "oldCost": 500}
  HIRED_EMPLOYEE // {"employeeName": "John", "role": "Barista"}
  DELETED_SHIFT // {"shiftId": "1234-5678", "reason": "sick leave"}
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  username        String    @unique
  passwordHash    String
  BusinessName    String
  createdAt       DateTime  @default(now())

  employees       Employee[]
  ActivityLog     ActivityLog[]
} 

model Employee {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  user          User        @relation(fields: [userId], references: [id])
  name          String
  role          String        //for now
  hourlyWage    Float
  maxDailyHours Float       @default(8)
  maxWeeklyHours Float      @default(40)
  minShiftHours Float       @default(3)
  stationSkills String[]    @default([])
  shifts        Shift[]
  availability  EmployeeAvailability[]
}

model Shift {
  id            String      @id @default(uuid()) @db.Uuid
  employeeId    String      @db.Uuid
  employee      Employee    @relation(fields: [employeeId], references: [id])
  startTime     DateTime
  endTime       DateTime
  station       String?
  breakMinutes  Int         @default(0)
  isOptimised   Boolean     @default(false) // optimised or nah

  @@unique([employeeId, startTime, endTime])
}

model EmployeeAvailability {
  id            String      @id @default(uuid()) @db.Uuid
  employeeId    String      @db.Uuid
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dayOfWeek     Int?        // 0 = Sunday, 1 = Monday, etc. Used for weekly repeating availability.
  date          DateTime?   // Optional date-specific override.
  startTime     String      // "09:00"
  endTime       String      // "17:00"
  isAvailable   Boolean     @default(true)

  @@index([employeeId, dayOfWeek])
  @@index([employeeId, date])
}

model ActivityLog {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  user          User        @relation(fields: [userId], references: [id])
  actionType    ActionType
  metadata      Json?

  createdAt     DateTime    @default(now())
}
